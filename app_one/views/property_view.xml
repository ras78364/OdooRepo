<odoo>
    <record id="property_view_list" model="ir.ui.view">
        <field name="name">property list</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <list class="header_custom" decoration-danger="(is_late)">
                <header>
                    <button name="property_xlsx_report" type="object" string="Print Excel Report" class="btn-primary"/>
                </header>
                <field name="name" width="150px"/>
                <field name="postcode" width="150px"/>
                <field name="is_late" width="150px" invisible="1"/>
                <field name="owner_id"/>
                <field name="date_availability" width="150px"/>
                <field name="selling_price" width="150px"/>
                <field name="garden" width="150px"/>
                <field name="facades" width="150px"/>
                <field name="state" width="150px"/>
                <field name="garden_area" width="150px"/>
                <field name="bedrooms" width="150px" optional="show"/>
                <field name="garage" width="150px" optional="show"/>
                <field name="active" width="150px" optional="show"/>
            </list>
        </field>
    </record>

    <record id="property_view_form" model="ir.ui.view">
        <field name="name">property form</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div name="button_box" class="oe_button_box">
                       <button name="action_open_related_owner" type="object"  string="Owner"
                        invisible="not owner_id"/>
                    </div>
                    <header>
                        <button name="action" type="object" class="btn-primary" string="Action"/>
                        <button name="get_properties" type="object" class="btn-primary" string="Test Call Get Properties"/>
                        <button name="action_draft" type="object" class="btn-primary" string="Set To Draft"
                        invisible="state in('draft','closed')"/>

                        <button name="action_pending" type="object" class="btn-secondary" string="Pending"
                        invisible="state!= 'draft'"/>
                        <button name="action_sold" type="object" class="btn-success" string="Sold"
                        invisible="state!= 'pending'"/>

                        <field name="state" widget="statusbar"  />

                    </header>
                    <div class="oe_title">
                        <label for="ref"/>
                        <h1>
                            <field name="ref"/>
                        </h1>
                        <label for="name"/>
                        <h3>
                            <field name="name" readonly="state == 'closed'"/>
                        </h3>
                    </div>
                    <group>
                        <group string="General Info.">
                            <field name="create_time" readonly="1"/>
                            <field name="next_time"/>
                            <field name="date_availability" required="1" readonly="state == 'closed'"/>
                            <field name="expected_selling_date" readonly="state == 'closed'"/>
                            <field name="is_late" invisible="1" readonly="state == 'closed'"/>
                            <field name="postcode" readonly="state == 'closed'"/>
                            <field name="expected_price" readonly="state == 'closed'"/>
                            <field name="selling_price" readonly="state == 'closed'"/>
                            <field name="difference" readonly="state == 'closed'"/>
                            <field name="living_area" readonly="state == 'closed'"/>
                            <field name="facades" readonly="state == 'closed'"/>

                        </group>

                        <group string="Additional Info.">
                            <field name="owner_id" readonly="state == 'closed'"/>
                            <field name="owner_address" readonly="state == 'closed'"/>
                            <field name="owner_phone" readonly="state == 'closed'"/>
                            <field name="state" readonly="state == 'closed'"/>
                            <field name="garden_area" readonly="state == 'closed'"/>
                            <field name="bedrooms" readonly="state == 'closed'"/>
                            <field name="garage" readonly="state == 'closed'"/>
                            <field name="garden" readonly="state == 'closed'"/>
                            <field name="garden_orientation" readonly="state == 'closed'"/>
                            <field name="active" readonly="state == 'closed'"/>
                            <field name="tag_ids" widget="many2many_tags" readonly="state == 'closed'"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" required="1"/>
                    </group>
                    <notebook>
                        <page string="Bedrooms">
                            <field name="line_ids" readonly="state == 'closed'">
                                <list editable="bottom">
                                    <field name="description"/>
                                    <field name="area"/>
                                </list>
                            </field>

                        </page>
                    </notebook>
                </sheet>
                <chatter>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>

                </div>
                </chatter>
            </form>
        </field>
    </record>

    <record id="property_view_search" model="ir.ui.view">
        <field name="name">property search</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <search>
                <field name="postcode"/>
                <field name="name"/>
                <filter name="is_garden" string="With Garden" domain="[('garden','=',True)]"/>
                <filter name="is_not_garden" string="Without Garden" domain="[('garden','=',False)]"/>
                <filter name="garage" string="With garage" domain="[('garage','=',True)]"/>
                <filter name="group_garden" string="Garden" context="{'group_by':'garden'}"/>
            </search>
        </field>
    </record>

    <record id="property_action" model="ir.actions.act_window">
        <field name="name">Property Action</field>
        <field name="res_model">property</field>
        <field name="view_mode">list,form</field>
    </record>
<record id="property_closed_server_action" model="ir.actions.server">
    <field name="name">Closed</field>
    <field name="model_id" ref="model_property"/>
    <field name="binding_model_id" ref="model_property"/>
    <field name="state">code</field>
    <field name="code">
        action= records.action_closed()
    </field>

</record>

    <record id="change_state_server_action" model="ir.actions.server">
    <field name="name">Change State</field>
    <field name="model_id" ref="model_property"/>
    <field name="binding_model_id" ref="model_property"/>
    <field name="state">code</field>
    <field name="code">
        action= records.action_open_change_state_wizard()
    </field>

</record>
    <record id="check_selling_date_cron" model="ir.cron">
        <field name="name">Property: Check Selling Date</field>
        <field name="model_id" ref="model_property"/>
        <field name="state">code</field>
        <field name="code">model.check_expected_selling_date()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>

    </record>
    <menuitem
        id="property_menu_item"
        name="Properties"
        parent="properties_menu"
        action="property_action"/>

    <record id="list_view_action" model="ir.actions.client">
        <field name="name">Properties List View</field>
        <field name="tag">app_one.action_list_view</field>
    </record>

    <menuitem
        id="property_list_view_menu_item"
        name="Properties OWL"
        parent="properties_menu"
        action="list_view_action"/>
</odoo>