<odoo>
     <record id="check_approval_reason_wizard_form" model="ir.ui.view">
    <field name="name">check.approval.reason.wizard.form</field>
    <field name="model">sale.approval.wizard</field>
    <field name="arch" type="xml">
        <form>
            <group>
                <field name="reason"/>
            </group>
            <footer>
                <button string="Confirm" type="object" name="approve" class="btn-primary"/>
                <button string="Cancel" special="cancel" class="btn-secondary"/>
            </footer>
        </form>
    </field>
    </record>
<record id="action_approval_wizard" model="ir.actions.act_window">
        <field name="name">Approve Margin</field>
        <field name="res_model">sale.approval.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>


</odoo>
