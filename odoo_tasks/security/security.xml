<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Groups must not be noupdate so upgrades always ensure they exist -->
    <record id="sale_manager_group" model="res.groups">
        <field name="name">Sales Price Manager</field>
        <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
    </record>

    <record id="inventory_manager_group" model="res.groups">
        <field name="name">Inventory Manager</field>
        <field name="implied_ids" eval="[(4, ref('account.group_account_invoice'))]"/>
    </record>

    <record id="group_accounting_cashier" model="res.groups">
        <field name="name">Authorized Payment Registrar</field>
        <field name="comment">Users allowed to register invoice/bill payments.</field>
        <field name="implied_ids" eval="[(4, ref('account.group_account_invoice'))]"/>
    </record>

    <record id="group_picking_validator" model="res.groups">
        <field name="name">Picking Validator</field>
        <field name="comment">Users allowed to validate deliveries.</field>
        <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]"/>
    </record>

    <data noupdate="1">
        <record id="sale_record_rule_by_user" model="ir.rule">
            <field name="name">sale.record.by.user</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>


        <record id="stock_picking_warehouse_rule" model="ir.rule">
            <field name="name">Restrict Transfers by Warehouse</field>
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="domain_force">['|', ('picking_type_id.warehouse_id', 'in', user.warehouse_ids.ids),
                ('picking_type_id.warehouse_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('stock.group_stock_user'))]"/>
        </record>
    </data>
</odoo>