<odoo>
   <record id="report_by_salesman" model="ir.actions.report">
        <field name="name">Report By Salesman</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
        <field name="report_name">odoo_tasks.report_by_salesman_template</field>
    </record>
    <template id="report_by_salesman_template">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <style>
                    table {
                        width: 100%;
                        border-collapse: collapse;
                    }
                    th, td {
                        border: 1px solid #b3adad;
                        padding: 6px;
                    }
                    th {
                        background: #f0f0f0;
                    }
                </style>
                <h1>Report By Salesman</h1>
                <p t-if="salesperson and salesperson.name"><strong>Salesperson:</strong> <t t-esc="salesperson.name"/></p>
                <p t-if="start_date"><strong>From:</strong> <t t-esc="start_date"/></p>
                <p t-if="end_date"><strong>To:</strong> <t t-esc="end_date"/></p>

                <table>
                    <thead>
                        <tr>
                            <th>Order</th>
                            <th>Customer</th>
                            <th>Salesperson</th>
                            <th>Date</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="docs" t-as="record">
                            <tr>
                                <td><t t-esc="record.name"/></td>
                                <td><t t-esc="record.partner_id.display_name"/></td>
                                <td><t t-esc="record.user_id.name"/></td>
                                <td><t t-esc="record.date_order"/></td>
                                <td><t t-esc="record.amount_total"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </t>
        </t>
    </template>
</odoo>