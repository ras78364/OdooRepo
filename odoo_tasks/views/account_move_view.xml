<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_form_inherit_vat_v3" model="ir.ui.view">
        <field name="name">view.account.move.form.inherit.vat</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
               <group string="Payment Status Summary">
        <group>
            <field name="payment_info_total" readonly="1"/>
            <field name="payment_info_paid" readonly="1"/>
        </group>
        <group>
            <field name="payment_info_residual" readonly="1"/>
            <field name="payment_info_state" widget="badge" decoration-success="payment_info_state == 'Paid'" decoration-warning="payment_info_state == 'Partially Paid'"/>
        </group>
    </group>
                <!-- Adding a field called Vat,
                so we check if it is filled before posting the invoice -->
            </xpath>
            <xpath expr="//div[@name='due_date']" position="after">
                <field name="partner_vat" readonly="1"/>
            </xpath>
            <xpath expr="//header" position="inside">
                <button type="object" name="action_post" string="Post Invoice" class="btn-primary" invisible="state != 'draft'" groups="odoo_tasks.group_accounting_cashier"/>
                <button type="object" name="action_approve" string="Approve" class="btn-primary" invisible="state != 'pending_approval'"/>
            </xpath>

          <xpath expr="//field[@name='invoice_payment_term_id']" position="replace">
                <!-- Editable field for your authorized manager/cashier group -->
                <field name="invoice_payment_term_id" groups="odoo_tasks.group_accounting_cashier"/>
                <!-- Read-only field for everyone else -->
                <field name="invoice_payment_term_id" readonly="1" groups="!odoo_tasks.group_accounting_cashier"/>
            </xpath>
        </field>
    </record>

    <record id="view_move_form_restrict_accounting" model="ir.ui.view">
        <field name="name">account.move.form.restrict.accounting</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Hide any existing journal field instances for everyone, then provide an admin-only journal field -->

            <!-- Add an admin-only visible journal field in the header area -->
            <xpath expr="//sheet" position="inside">
                <group position="inside">
                    <field name="journal_id" groups="base.group_system"/>
                </group>
            </xpath>
            <xpath expr="//field[@name='journal_id']" position="replace">
                <!-- Editable field for your authorized manager/cashier group -->
                <field name="journal_id" groups="base.group_system"/>
                <!-- Read-only field for everyone else -->
                <field name="journal_id" readonly="1" groups="!base.group_system"/>
            </xpath>

            <xpath expr="//page[@name='aml_tab']" position="attributes">
                <attribute name="groups">base.group_system</attribute>
            </xpath>


        </field>
    </record>

    <!-- check invoice cancellation reason -->
  <record id="check_invoice_cancellation_reason_wizard_form" model="ir.ui.view">
    <field name="name">check.invoice.cancellation.reason.wizard.form</field>
    <field name="model">check.invoice.cancellation</field>
    <field name="arch" type="xml">
        <form>
            <group>
                <field name="Invoice_cancellation_reason"/>
            </group>
            <footer>
                <button string="Confirm" type="object" name="action_confirm_cancellation" class="btn-primary"/>
                <button string="Cancel" special="cancel" class="btn-secondary"/>
            </footer>
        </form>
    </field>
</record>

    <record id="check_invoice_cancellation_reason_server_action" model="ir.actions.server">
        <field name="name">Cancel Invoice</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="state">code</field>
        <field name="code">
            action = records._invoice_cancellation_reason()
        </field>
    </record>

    <record id="check_invoice_cancellation_reason_action" model="ir.actions.act_window">
        <field name="name">Check Invoice Cancellation Reason</field>
        <field name="res_model">check.invoice.cancellation</field>
        <field name="target">new</field>
        <field name="view_mode">form</field>
    </record>

    <!-- Pay button: only Authorized Payment Registrar -->
    <record id="view_move_form_inherit_payment_group" model="ir.ui.view">
        <field name="name">account.move.form.inherit.payment.group</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_register_payment']" position="attributes">
                <attribute name="groups">odoo_tasks.group_accounting_cashier</attribute>
            </xpath>
            <xpath expr="//button[@name='action_post']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>


        </field>
    </record>

    <!-- report by unpaid invoice -->
    <record id="view_report_by_unpaid_invoice_wizard_form" model="ir.ui.view">
        <field name="name">report.by.unpaid.invoice.wizard.form</field>
        <field name="model">report.by.unpaid.invoice.wizard</field>
        <field name="arch" type="xml">
            <form string="Unpaid Invoices Report Wizard">
            <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                </sheet>
            <footer>
                <button name="action_print_report" type="object" string="Print PDF" class="btn-primary"/>
                <button string="Cancel" class="btn-secondary" special="cancel"/>

            </footer>
            </form>
        </field>
    </record>


     <record id="action_report_by_unpaid_invoice_wizard" model="ir.actions.act_window">
        <field name="name">Report By Unpaid Invoice</field>
        <field name="res_model">report.by.unpaid.invoice.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_invoice_list_inherit" model="ir.ui.view">
    <field name="name">view_invoice_list_inherit</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_out_invoice_tree"/>
    <field name="arch" type="xml">

        <xpath expr="//header" position="inside">
            <button name="%(odoo_tasks.action_report_by_unpaid_invoice_wizard)d" type="action"
                    string="Unpaid Invoices Report" class="btn-primary"/>
        </xpath>
    </field>
</record>
</odoo>
