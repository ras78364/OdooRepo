<odoo>
    <record id="view_customer_orders_form_inherit" model="ir.ui.view">
        <field name="name">view.customer.orders.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="display_partner_orders"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-usd" string="Orders">

                </button>
            </xpath>

           <xpath expr="//field[@name='phone']" position="after">
                <div class="mt8">
                    <label for="client_phone" string="Customer Phone"/>
                    <field name="client_phone"/>
                </div>
                <div class="mt8">
                    <label for="internal_client_code" string="Customer Code"/>
                    <field name="internal_client_code"/>
                </div>
            </xpath>
        </field>
    </record>

    <record id="partner_orders_action" model="ir.actions.act_window">
    <field name="name">Partner Sale Orders</field>
    <field name="res_model">sale.order</field>
    <field name="view_mode">list,form</field>
</record>
</odoo>