    <!-- check_customer_data -->

    <record id="sale_order_view_list_inherit" model="ir.ui.view">
        <field name="name">sale.order.list.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="client_phone" readonly="1"/>
                <field name="client_vat" readonly="1"/>
                <field name="internal_client_code" readonly="1"/>
            </xpath>

        </field>
    </record>
    <record id="sale_order_view_form_inherit_check" model="ir.ui.view">
        <field name="name">sale.order.form.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//list//field[@name='price_unit']" position="replace">
            <field name="price_unit" groups="base.group_system,odoo_tasks.sale_manager_group"/>
            <field name="price_unit" readonly="1" groups="!base.group_system,!odoo_tasks.sale_manager_group"/>
        </xpath>
<!--            <xpath>-->

<!--&lt;!&ndash;                <field name="price_unit" readonly="qty_invoiced &gt; 0" groups="odoo_tasks.sale_manager_group"/>&ndash;&gt;-->
<!--&lt;!&ndash;                <field name="price_unit" readonly="1" groups="!odoo_tasks.sale_manager_group"/>&ndash;&gt;-->
<!--            </xpath>-->
            <xpath expr="//sheet" position="inside">
                <group string="Customer Information">
                    <group>
                        <field name="client_phone"/>
                    </group>
                    <group>
                        <field name="client_vat"/>
                        <field name="internal_client_code"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
    <!-- check_customer_data -->

<record id="sale_order_view_form_status" model="ir.ui.view">
    <field name="name">sale.order.view.form.status</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_order_form"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='state']" position="attributes">
            <attribute name="invisible">1</attribute>
        </xpath>
        <xpath expr="//header" position="inside">
            <button type="object" string="Approve" name="action_approve" class="btn-primary" invisible="state != 'waiting_approval'"/>
            <field name="state" widget="statusbar" statusbar_visible="draft,waiting_approval,sale,confirmed,cancelled"/>
        </xpath>
        <xpath expr="//button[@name='action_confirm'][2]" position="attributes">
            <attribute name="groups">base.group_system</attribute>
        </xpath>
    </field>
</record>

    <!-- report by salesman -->
    <record id="view_report_by_salesman_wizard_form" model="ir.ui.view">
        <field name="name">report.by.salesman.wizard.form</field>
        <field name="model">report.by.salesman.wizard</field>
        <field name="arch" type="xml">
            <form string="Salesman Report Wizard">
            <sheet>
                    <group>
                        <field name="salesperson_id"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>
                </sheet>
            <footer>
                <button name="action_print_report" type="object" string="Print PDF" class="btn-primary"/>
                <button string="Cancel" class="btn-secondary" special="cancel"/>

            </footer>
            </form>
        </field>
    </record>

    <record id="view_order_list_inherit_salesman_wizard" model="ir.ui.view">
    <field name="name">sale.order.list.inherit.salesman.wizard</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.sale_order_list_upload"/>
    <field name="arch" type="xml">

        <xpath expr="//header" position="inside">
            <button name="%(odoo_tasks.action_report_by_salesman_wizard)d" type="action"
                    string="Salesman Report" class="btn-primary"/>
        </xpath>
    </field>
</record>




    <record id="action_report_by_salesman_wizard" model="ir.actions.act_window">
        <field name="name">Report By Salesman</field>
        <field name="res_model">report.by.salesman.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>






    <menuitem id="odoo_tasks_menu_all_orders" name="All Orders"
              parent="odoo_tasks_menu_main"
              action="action_todo_task" sequence="1"/>

    <menuitem id="odoo_tasks_menu_all_pickings"
              name="All Pickings" parent="odoo_tasks_menu_main"
              action="stock.action_picking_tree_all" sequence="2"/>


</odoo>
