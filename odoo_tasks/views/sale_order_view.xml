<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_todo_task" model="ir.actions.act_window">
    <field name="name">Orders</field>
    <field name="res_model">sale.order</field>
    <field name="view_mode">list,form</field>
    <field name="group_ids" eval="[(5, 0, 0)]"/>

</record>

    <!-- check_discount_reason section -->
    <record id="check_discount_reason_wizard_view_form" model="ir.ui.view">
        <field name="name">check discount reason wizard form</field>
        <field name="model">check.discount.reason</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="order_id" invisible="1"/>
                    <field name="discount" required="1"/>
                    <field name="discount_reason" required="1"/>
                </group>
                    <footer>
                        <button string="Confirm" type="object" name="action_confirm_discount" class="btn-primary"/>
                        <button string="Cancel" special="cancel" class="btn-secondary"/>
                    </footer>
            </form>
        </field>
    </record>
     <record id="check_discount_reason_server_action" model="ir.actions.server">
        <field name="name">Discount</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="state">code</field>
        <field name="code">
            action = records._check_discount_reason()
        </field>
    </record>

    <record id="check_discount_reason_action" model="ir.actions.act_window">
        <field name="name">Check Discount Reason</field>
        <field name="res_model">check.discount.reason</field>
        <field name="target">new</field>
        <field name="view_mode">form</field>
    </record>

     <!-- check_order_cancellation -->
    <record id="check_order_cancellation_wizard_view_form" model="ir.ui.view">
    <field name="name">check.order.cancellation.form</field>
    <field name="model">check.sale.order.cancellation</field>
    <field name="arch" type="xml">
        <form>
            <group>
                <field name="order_id" invisible="1"/>
                <field name="cancel_reason" required="1"/>
            </group>
            <footer>
                <button string="Confirm" type="object" name="action_confirm_cancellation" class="btn-primary"/>
                <button string="Cancel" special="cancel" class="btn-secondary"/>
            </footer>
        </form>
    </field>
</record>

       <record id="check_cancellation_reason_server_action" model="ir.actions.server">
        <field name="name">Cancel Order</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="state">code</field>
        <field name="code">
            action = records._check_order_cancellation_reason()
        </field>
    </record>

    <record id="check_cancellation_reason_action" model="ir.actions.act_window">
        <field name="name">Check Cancellation Reason</field>
        <field name="res_model">check.sale.order.cancellation</field>
        <field name="target">new</field>
        <field name="view_mode">form</field>
    </record>




<!--    <record id="owner_action" model="ir.actions.act_window">-->
<!--        <field name="name">Owners</field>-->
<!--        <field name="res_model">owner</field>-->
<!--        <field name="view_mode">list,form</field>-->
